<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Angry Pets PRO - Online</title>
    <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #0a0a1a; color: white; font-family: 'Arial Black', sans-serif; overflow: hidden; touch-action: none; }
        #lobby { position: absolute; width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #0a0a1a; z-index: 100; text-align: center; padding: 20px; }
        input { padding: 10px; border-radius: 5px; border: none; margin: 10px; width: 250px; text-align: center; }
        button { padding: 10px 30px; background: #00d2ff; border: none; border-radius: 50px; cursor: pointer; font-weight: bold; margin: 5px; }
        #game-canvas { display: none; background: linear-gradient(#0a0a1a, #1a1a2e); margin: 0 auto; }
        #ui { position: absolute; top: 10px; width: 100%; display: none; justify-content: space-around; pointer-events: none; z-index: 10; font-size: 18px; }
    </style>
</head>
<body>

<div id="lobby">
    <h1>ONLINE VERSUS</h1>
    <div id="connection-controls">
        <p>Senin ID: <b id="my-id">...</b></p>
        <hr style="width:100%; margin:20px; opacity:0.2">
        <input type="text" id="peer-id-input" placeholder="Arkadaşının ID'sini Yaz">
        <br>
        <button id="connect-btn">ARKADAŞINA BAĞLAN</button>
        <p style="font-size: 10px; margin-top:10px; color:#aaa">Veya arkadaşının senin ID'ni yazmasını bekle.</p>
    </div>
    <div id="status">Sinyal bekleniyor...</div>
</div>

<div id="ui">
    <div style="color: #ff0055;">SEN: <span id="s1">0</span></div>
    <div style="color: #00d2ff;">RAKİP: <span id="s2">0</span></div>
</div>

<canvas id="game-canvas"></canvas>

<script>
    const canvas = document.getElementById('game-canvas');
    const ctx = canvas.getContext('2d');
    const raw = "https://raw.githubusercontent.com/darwin456222-ops/Darwiizl/main/";
    
    // --- NETWORK AYARLARI ---
    const peer = new Peer();
    let conn;
    let isHost = false;

    peer.on('open', (id) => {
        document.getElementById('my-id').innerText = id;
        document.getElementById('status').innerText = "ID Hazır! Arkadaşına gönder.";
    });

    // Birisi bize bağlandığında (Host oluruz)
    peer.on('connection', (c) => {
        conn = c;
        isHost = true;
        setupConnection();
    });

    // Biz birine bağlandığımızda (Client oluruz)
    document.getElementById('connect-btn').onclick = () => {
        const remoteId = document.getElementById('peer-id-input').value;
        conn = peer.connect(remoteId);
        isHost = false;
        setupConnection();
    };

    function setupConnection() {
        conn.on('open', () => {
            document.getElementById('lobby').style.display = 'none';
            document.getElementById('ui').style.display = 'flex';
            canvas.style.display = 'block';
            startGame();
        });

        conn.on('data', (data) => {
            if (data.type === 'update') {
                opponent.x = data.x;
                opponent.y = data.y;
                opponent.score = data.score;
            }
        });
    }

    // --- OYUN MANTIĞI ---
    let gameRunning = false;
    let cameraY = 0;
    let platforms = [];
    const player = { x: 200, y: 0, vx: 0, vy: 0, score: 0 };
    const opponent = { x: 200, y: 0, score: 0 };
    const img = new Image(); img.src = raw + "squeak.jpg";

    function startGame() {
        canvas.width = Math.min(window.innerWidth, 450);
        canvas.height = window.innerHeight;
        player.y = canvas.height - 100;
        
        // Host platformları oluşturur ve (gelecekte) paylaşır
        // Şimdilik basitleştirmek için her iki taraf aynı random seed kullanmalı 
        // veya platformları sabit yapalım:
        for (let i = 0; i < 100; i++) {
            platforms.push({ x: (i * 137) % (canvas.width - 80), y: canvas.height - (i * 150), w: 80, h: 15 });
        }
        gameRunning = true;
        draw();
    }

    function draw() {
        if(!gameRunning) return;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.save();
        ctx.translate(0, -cameraY);

        ctx.fillStyle = "white";
        platforms.forEach(p => ctx.fillRect(p.x, p.y, p.w, p.h));

        // Rakip (Mavi gölge)
        ctx.globalAlpha = 0.5;
        ctx.drawImage(img, opponent.x - 25, opponent.y - 25, 50, 50);
        ctx.globalAlpha = 1.0;

        // Sen
        ctx.drawImage(img, player.x - 25, player.y - 25, 50, 50);

        ctx.restore();
        update();
        requestAnimationFrame(draw);
    }

    function update() {
        player.vy += 0.45;
        player.y += player.vy;
        player.x += player.vx;

        // Platform Çarpışması
        if (player.vy > 0) {
            platforms.forEach(p => {
                if (player.x + 15 > p.x && player.x - 15 < p.x + p.w &&
                    player.y + 25 > p.y && player.y + 25 < p.y + p.h) {
                    player.vy = -14;
                }
            });
        }

        // Kamera Takibi (Kendi karakterine odaklı)
        if (player.y < cameraY + canvas.height / 2) cameraY = player.y - canvas.height / 2;

        player.score = Math.floor(Math.abs(player.y - (canvas.height - 100)) / 10);
        document.getElementById('s1').innerText = player.score;
        document.getElementById('s2').innerText = opponent.score;

        // Veriyi gönder
        if (conn && conn.open) {
            conn.send({ type: 'update', x: player.x, y: player.y, score: player.score });
        }
    }

    window.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        player.vx = (e.clientX - rect.left - player.x) * 0.1;
    });

    window.addEventListener('touchmove', (e) => {
        const rect = canvas.getBoundingClientRect();
        player.vx = (e.touches[0].clientX - rect.left - player.x) * 0.1;
    }, { passive: false });

</script>
</body>
</html>
