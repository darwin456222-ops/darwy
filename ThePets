<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>The Pets Jump Jousts</title>
    <style>
        body { margin: 0; background: #87CEEB; font-family: 'Arial Black', sans-serif; overflow: hidden; }
        
        /* CAN BARLARI (HUD) */
        #hud { position: absolute; width: 100%; display: flex; justify-content: space-between; padding: 20px; box-sizing: border-box; z-index: 10; }
        .player-info { display: flex; align-items: center; gap: 10px; }
        .pet-thumb { width: 50px; height: 50px; border-radius: 50%; border: 3px solid #000; background: #FFF; }
        
        .health-bar { width: 250px; height: 25px; background: #333; border: 4px solid #000; display: flex; overflow: hidden; }
        .health-fill { width: 100%; height: 100%; background: #00FF00; transition: 0.3s; }
        
        #timer { font-size: 30px; color: yellow; font-weight: bold; text-shadow: 2px 2px #000; }

        /* OYUN ALANI (STAGE) */
        #stage { width: 100vw; height: 100vh; position: relative; 
            /* Teen Titans koltuk odasına benzer bir arka plan */
            background-image: url('https://img.freepik.com/free-vector/modern-living-room-interior-design_23-2148139502.jpg'); 
            background-size: cover; background-position: center; }
        
        .pet { width: 150px; height: 150px; position: absolute; bottom: 80px; transition: transform 0.1s; display: flex; align-items: center; justify-content: center; }
        
        /* 2D Karakter Görselleri (Senin fotoğrafların) */
        .pet-sprite { width: 100%; height: 100%; object-fit: contain; }

        #pet1 { left: 100px; }
        #pet2 { right: 100px; transform: scaleX(-1); } /* 2. Oyuncuyu ters çevir */

        /* KONTROLLER (Jump Jousts stili) */
        #controls { position: absolute; bottom: 20px; width: 100%; display: flex; justify-content: center; gap: 20px; z-index: 10; }
        .btn { width: 70px; height: 70px; background: #FFF; border: 4px solid #333; border-radius: 15px; font-weight: bold; font-size: 14px; display: flex; align-items: center; justify-content: center; cursor: pointer; user-select: none; transition: 0.1s; }
        .btn:active { transform: translateY(3px); filter: brightness(0.9); }
        .special-btn { background: #00FFFF; color: #000; } /* Special butonu turkuaz */
    </style>
</head>
<body>

<div id="hud">
    <div class="player-info">
        <img id="thumb1" src="" class="pet-thumb" alt="P1"> 
        <div class="health-bar"><div id="hp1" class="health-fill"></div></div>
    </div>
    
    <div id="timer">99</div>
    
    <div class="player-info" style="flex-direction: row-reverse;">
        <img id="thumb2" src="" class="pet-thumb" alt="P2">
        <div class="health-bar"><div id="hp2" class="health-fill"></div></div>
    </div>
</div>

<div id="stage">
    <div id="pet1" class="pet">
        <img id="sprite1" src="" class="pet-sprite" alt="Pet 1">
    </div>
    
    <div id="pet2" class="pet">
        <img id="sprite2" src="" class="pet-sprite" alt="Pet 2">
    </div>
</div>

<div id="controls">
    <div class="btn" onclick="jumpAction(1)">JUMP</div>
    <div class="btn" onclick="attackAction(1)">ATTACK</div>
    <div class="btn special-btn" onclick="specialAction(1)">S</div>
</div>

<script>
    // --- FOTOĞRAF LİNKLERİ BURAYA ---
    const petPhotos = {
        Squeak: "Squeak.jpg",
        Flip:   "Flip.jpg",
        Sugar:  Sugar.jpg",
        Dot:    "Dot.jpg",
        Gus:    "Gus.jpg",
        Blinky: "Blinky.jpg"
    // --------------------------------

    // Kim kiminle dövüşüyor? (Rastgele seçelim)
    let p1 = "Squeak";
    let p2 = "Gus";

    // Karakterleri ve İkonları Yükleme
    document.getElementById('sprite1').src = petPhotos[p1];
    document.getElementById('thumb1').src = petPhotos[p1];
    
    document.getElementById('sprite2').src = petPhotos[p2];
    document.getElementById('thumb2').src = petPhotos[p2];

    // TEMEL HAREKETLER (Jump Jousts Mantığı)
    function jumpAction(p) {
        const pet = document.getElementById('pet' + p);
        if(pet.style.bottom === '200px') return; // Havadaysa zıplama
        
        pet.style.bottom = '200px';
        setTimeout(() => { pet.style.bottom = '80px'; }, 350); // Jump Jousts gibi hızlı iniş
    }

    function attackAction(p) {
        const pet = document.getElementById('pet' + p);
        const direction = p === 1 ? 150 : -150; // İleriye fırla
        
        pet.style.transform += ` translateX(${direction}px)`;
        
        // Rakibe çarpıp can azaltma (Sadeleştirilmiş mantık)
        setTimeout(() => {
            pet.style.transform = p === 1 ? 'scaleX(1)' : 'scaleX(-1)';
            const enemyHPBar = document.getElementById('hp' + (p === 1 ? 2 : 1));
            enemyHPBar.style.width = (parseInt(enemyHPBar.style.width) || 100) - 10 + "%";
        }, 200);
    }
</script>

</body>
</html>